# Supabase database URL used by Prisma migrations.
# Use a direct/session database connection, not the public API URL.
DATABASE_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres"

# Optional Supabase database URL for Prisma migrate dev shadow database work.
SHADOW_DATABASE_URL="postgresql://postgres:password@db.shadow-project-ref.supabase.co:5432/postgres?schema=public"
